{
    "name": "aidentally",
    "version": "0.0.0",
    "description": "A dental clinic management system with AI assistant",
    "main": "build/index.js",
    "type": "module",
    "scripts": {
        "dev": "pnpm run start:dev",
        "start:dev": "NODE_ENV=development concurrently \"rollup -c -w\" \"nodemon -w build --exec 'node build/index.js'\"",
        "dev:debug": "NODE_ENV=development concurrently \"rollup -c -w\" \"nodemon -w build --exec 'node --inspect build/index.js'\"",
        "dev:docker": "NODE_ENV=development docker compose -f docker-compose.dev.yml --profile dev up",
        "dev:docker:clean": "docker system prune -a -f --volumes && pnpm run dev:docker",
        "start": "node build/index.js",
        "build": "pnpm run clean && rollup -c",
        "clean": "rimraf build",
        "test": "NODE_ENV=development vitest run",
        "test:watch": "NODE_ENV=development vitest",
        "test:ci": "NODE_ENV=ci vitest run",
        "test:docker:watch": "docker compose -f docker-compose.watch.test.yml up --abort-on-container-exit",
        "test:docker:watch:down": "docker compose -f docker-compose.watch.test.yml down -v",
        "lint": "eslint --ext .ts src",
        "lint:fix": "eslint --ext .ts src --fix",
        "format": "prettier --write \"src/**/*.{ts,js,json}\" --list-different",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
        "typecheck": "tsc --noEmit",
        "prepare": "husky install",
        "db:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d && sleep 15 && docker exec -e NODE_ENV=development typescript-backend npx sequelize-cli db:migrate && docker exec -e NODE_ENV=development typescript-backend npx sequelize-cli db:seed:all"
    },
    "author": "Kien Ha",
    "license": "MIT",
    "devDependencies": {
        "@commitlint/cli": "^19.8.0",
        "@commitlint/config-conventional": "^19.8.0",
        "@redis/client": "^1.6.0",
        "@rollup/plugin-alias": "^5.1.0",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-typescript": "^11.1.6",
        "@rollup/wasm-node": "4.39.0",
        "@testcontainers/mysql": "^10.24.0",
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.12",
        "@types/express": "^5.0.1",
        "@types/gapi": "^0.0.42",
        "@types/i18n": "^0.13.12",
        "@types/lodash": "^4.14.182",
        "@types/mocha": "^10.0.10",
        "@types/node-cron": "^3.0.1",
        "@types/passport-jwt": "^3.0.7",
        "@types/sinon": "^10.0.13",
        "@types/supertest": "^6.0.3",
        "@vitest/coverage-v8": "^3.1.1",
        "@vitest/ui": "^3.1.1",
        "concurrently": "^8.2.0",
        "eslint": "^8.13.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-airbnb-typescript": "^17.0.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-import-resolver-typescript": "^2.7.1",
        "eslint-plugin-import": "^2.24.2",
        "eslint-plugin-prettier": "^4.0.0",
        "eslint-plugin-promise": "^6.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.0",
        "nodemon": "^2.0.15",
        "prettier": "^2.8.8",
        "rimraf": "^5.0.5",
        "rollup": "^4.12.0",
        "supertest": "^7.1.0",
        "swagger-ui-express": "^5.0.1",
        "ts-node": "^10.9.2",
        "ts-sinon": "^2.0.2",
        "tsconfig-paths": "^4.2.0",
        "tslib": "^2.6.2",
        "typescript": "^4.6.3",
        "vitest": "^3.1.1",
        "yaml": "^2.7.1"
    },
    "dependencies": {
        "axios": "^0.26.1",
        "bcrypt": "^5.1.1",
        "chai": "^4.3.7",
        "chokidar": "^3.5.3",
        "cors": "^2.8.5",
        "date-fns": "^2.28.0",
        "date-fns-tz": "^1.3.4",
        "dotenv": "^16.0.0",
        "express": "^4.21.2",
        "form-data": "^4.0.0",
        "googleapis": "^100.0.0",
        "helmet": "^6.0.1",
        "http-status": "^1.5.0",
        "i18n": "^0.15.1",
        "ioredis": "^5.6.0",
        "jsonwebtoken": "^8.5.1",
        "lodash": "^4.17.21",
        "mocha": "^10.1.0",
        "mysql2": "^2.3.3",
        "node-cron": "^3.0.0",
        "passport": "^0.6.0",
        "passport-jwt": "^4.0.0",
        "rate-limiter-flexible": "^7.0.0",
        "redis": "^4.3.1",
        "sequelize": "^6.18.0",
        "sequelize-cli": "^6.4.1",
        "socket.io": "^4.8.1",
        "source-map-support": "^0.5.21",
        "uuid": "^11.1.0",
        "winston": "^3.7.2",
        "winston-daily-rotate-file": "^4.6.1",
        "zod": "^3.24.2",
        "zod-validation-error": "^3.4.0"
    },
    "pnpm": {
        "neverBuiltDependencies": []
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-arm64-musl": "^4.39.0",
        "@rollup/rollup-linux-x64-gnu": "4.9.5"
    },
    "resolutions": {
        "rollup": "npm:@rollup/wasm-node",
        "tslib": "^2.6.2"
    }
}
