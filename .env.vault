#/-------------------.env.vault---------------------/
#/         cloud-agnostic vaulting standard         /
#/   [how it works](https://dotenv.org/env-vault)   /
#/--------------------------------------------------/

# development
DOTENV_VAULT_DEVELOPMENT=""
DOTENV_VAULT_DEVELOPMENT_VERSION=4

# staging
DOTENV_VAULT_STAGING=""
DOTENV_VAULT_STAGING_VERSION=4

# production
DOTENV_VAULT_PRODUCTION=""
DOTENV_VAULT_PRODUCTION_VERSION=4

# ci
DOTENV_VAULT_CI=""
DOTENV_VAULT_CI_VERSION=5

#/----------------settings/metadata-----------------/
DOTENV_VAULT="vlt_8bf55236fe807f7787775c7e9837338028ce84d4a9bb53e555fa8018a9b32817"
DOTENV_API_URL="https://vault.dotenv.org"
DOTENV_CLI="npx dotenv-vault@latest"
